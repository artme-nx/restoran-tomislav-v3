{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "parchment": {
        "50": { "$value": "#FBF6EA", "$type": "color" },
        "100": { "$value": "#F3E8D0", "$type": "color" },
        "300": { "$value": "#E3CFA4", "$type": "color" },
        "500": { "$value": "#C7A874", "$type": "color" },
        "700": { "$value": "#8C6B3F", "$type": "color" }
      },
      "ink": {
        "500": { "$value": "#5B4A32", "$type": "color" },
        "700": { "$value": "#3C3020", "$type": "color" },
        "900": { "$value": "#241A0F", "$type": "color" }
      },
      "adriatic": {
        "300": { "$value": "#4C8A94", "$type": "color" },
        "500": { "$value": "#1E5C69", "$type": "color" },
        "700": { "$value": "#123C45", "$type": "color" }
      },
      "wax": {
        "300": { "$value": "#C25A3D", "$type": "color" },
        "500": { "$value": "#A13820", "$type": "color" },
        "700": { "$value": "#712616", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-cormorant), 'Cormorant Garamond', Georgia, serif", "$type": "fontFamily" },
      "serif": { "$value": "var(--font-eb-garamond), 'EB Garamond', Georgia, serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-plex-mono), 'IBM Plex Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "unfurl": { "$value": "1.4s", "$type": "duration" },
        "stamp": { "$value": "0.7s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "stamp": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "0.01em", "$type": "dimension" },
      "label": { "$value": "0.22em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.parchment.100}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "popover": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "primary": { "$value": "{primitive.color.wax.500}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.adriatic.500}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "muted": { "$value": "{primitive.color.parchment.300}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ink.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.adriatic.500}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.wax.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.parchment.500}", "$type": "color" },
    "input": { "$value": "{primitive.color.parchment.500}", "$type": "color" },
    "ring": { "$value": "{primitive.color.wax.500}", "$type": "color" },
    "radius": { "$value": "0.125rem", "$type": "dimension" },
    "wax": { "$value": "{primitive.color.wax.500}", "$type": "color" },
    "wax-dim": { "$value": "{primitive.color.wax.700}", "$type": "color" },
    "adriatic": { "$value": "{primitive.color.adriatic.500}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.parchment.500}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.serif}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-stamp": { "$value": "{primitive.motion.ease.stamp}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-unfurl": { "$value": "{primitive.motion.duration.unfurl}", "$type": "duration" },
    "duration-stamp": { "$value": "{primitive.motion.duration.stamp}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "charter": {
      "spine-width": { "$value": "clamp(3px, 0.6vw, 6px)", "$type": "dimension" },
      "seal-size": { "$value": "clamp(4.5rem, 9vw, 7rem)", "$type": "dimension" },
      "grain": {
        "$value": "radial-gradient(circle at 20% 30%, rgba(140, 107, 63, 0.08), transparent 45%), radial-gradient(circle at 80% 70%, rgba(140, 107, 63, 0.07), transparent 50%), radial-gradient(circle at 50% 95%, rgba(30, 92, 105, 0.05), transparent 60%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to bottom, rgba(36, 26, 15, 0.10), transparent 18%, transparent 82%, rgba(36, 26, 15, 0.12) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.wax.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.wax.700}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.parchment.50}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.parchment.700}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.adriatic.500}", "$type": "color" }
    }
  }
}
